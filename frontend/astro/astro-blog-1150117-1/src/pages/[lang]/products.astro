---
import { getCollection } from 'astro:content'
export const getStaticPaths = () => {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh-tw' } }]
}
const { lang } = Astro.params
const allProducts = await getCollection('products', ({ id }) =>
  id.startsWith(lang)
)

import Layout from '../../layouts/Layout.astro'
---

<div class="p-8 bg-dashboard-bg min-h-screen">
  <Layout>
    <main data-pagefind-body data-pagefind-filter={`language:${lang}`}>
      <h1 class="text-3xl font-bold mb-6">Product Explore ({lang})</h1>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {
          allProducts.map((product) => (
            <div
              data-pagefind-index-attrs="title"
              class="bg-white p-4 rounded-xl shadow-sm border border-gray-200"
            >
              <h2 data-pagefind-meta="title" class="text-xl font-semibold">
                {product.data.title}
              </h2>
              <p data-pagefind-meta="description" class="text-gray-500">
                {product.data.description}
              </p>
              <div data-pagefind-meta="price" class="mt-4 font-mono text-brand">
                ${product.data.price}
              </div>
            </div>
          ))
        }
      </div>
    </main>
  </Layout>
</div>
